# =============================================================================
# LLM PROVIDER CONFIGURATION
# =============================================================================
# Choose your LLM provider by setting LLM_PROVIDER and corresponding API key
# Supported: openai, anthropic, openrouter, groq, together, replicate, cohere, 
#            ollama, localai, lmstudio, huggingface, deepinfra, anyscale
# =============================================================================

LLM_PROVIDER=ollama
LLM_MODEL=llama3.2
LLM_API_KEY=
LLM_BASE_URL=http://localhost:11434

# =============================================================================
# OPENROUTER (Recommended - Access 100+ models with ONE API key)
# =============================================================================
# Get API key: https://openrouter.ai/keys
# Pricing: Pay-per-use, starts at $0.0001/1K tokens
# Free tier: $5 credit for testing
# Models: GPT-4, Claude, Llama, Mistral, Gemini, and 100+ more
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_MODEL=openai/gpt-4-turbo-preview
# OPENROUTER_MODEL=anthropic/claude-3-opus
# OPENROUTER_MODEL=meta-llama/llama-3.1-70b-instruct
# OPENROUTER_MODEL=google/gemini-pro-1.5
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# =============================================================================
# GROQ (FREE - Extremely Fast Inference)
# =============================================================================
# Get API key: https://console.groq.com/keys
# Pricing: FREE tier with generous limits (14 requests/minute)
# Speed: 10x faster than traditional cloud providers
# Models: Llama 3, Mixtral, Gemma
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.1-70b-versatile
# GROQ_MODEL=mixtral-8x7b-32768
# GROQ_MODEL=gemma-7b-it
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# =============================================================================
# TOGETHER AI (Generous Free Tier)
# =============================================================================
# Get API key: https://api.together.xyz/settings/api-keys
# Pricing: $25 free credit, then $0.0001-0.0008/1K tokens
# Models: Llama, Mistral, Qwen, DeepSeek
# TOGETHER_API_KEY=...
# TOGETHER_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct-Turbo
# TOGETHER_MODEL=mistralai/Mixtral-8x7B-Instruct-v0.1
# TOGETHER_MODEL=Qwen/Qwen2.5-72B-Instruct-Turbo
# TOGETHER_BASE_URL=https://api.together.xyz/v1

# =============================================================================
# DEEPINFRA (Free Tier Available)
# =============================================================================
# Get API key: https://deepinfra.com/dash/api_keys
# Pricing: Free tier available, then pay-per-use
# Models: Llama, Mistral, Qwen, Gemma
# DEEPINFRA_API_KEY=...
# DEEPINFRA_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct
# DEEPINFRA_MODEL=mistralai/Mixtral-8x7B-Instruct-v0.1
# DEEPINFRA_BASE_URL=https://api.deepinfra.com/v1/openai

# =============================================================================
# ANYSCALE ENDPOINTS (Free Tier)
# =============================================================================
# Get API key: https://app.endpoints.anyscale.com/credentials
# Pricing: $10 free credit, OpenAI-compatible API
# Models: Llama, Mistral, Codestral
# ANYSCALE_API_KEY=esecret_...
# ANYSCALE_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct
# ANYSCALE_MODEL=mistralai/Mixtral-8x7B-Instruct-v0.1
# ANYSCALE_BASE_URL=https://api.endpoints.anyscale.com/v1

# =============================================================================
# HUGGING FACE INFERENCE API (Free Tier)
# =============================================================================
# Get API key: https://huggingface.co/settings/tokens
# Pricing: Free tier available (rate-limited), Pro at $9/month
# Models: 1000+ open-source models
# HUGGINGFACE_API_KEY=hf_...
# HUGGINGFACE_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct
# HUGGINGFACE_MODEL=mistralai/Mixtral-8x7B-Instruct-v0.1
# HUGGINGFACE_BASE_URL=https://api-inference.huggingface.co/models

# =============================================================================
# REPLICATE (Pay-per-use, Affordable)
# =============================================================================
# Get API key: https://replicate.com/account/api-tokens
# Pricing: Pay only for what you use, $0.0001-0.002/second
# Models: Llama, FLUX, Stable Diffusion, Whisper
# REPLICATE_API_KEY=r8_...
# REPLICATE_MODEL=meta/meta-llama-3.1-405b-instruct

# =============================================================================
# OPENAI (Standard Provider)
# =============================================================================
# Get API key: https://platform.openai.com/api-keys
# Pricing: Starts at $0.002/1K tokens (GPT-3.5), GPT-4 higher
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4-turbo-preview
# OPENAI_MODEL=gpt-3.5-turbo
# OPENAI_BASE_URL=https://api.openai.com/v1

# =============================================================================
# ANTHROPIC CLAUDE
# =============================================================================
# Get API key: https://console.anthropic.com/account/keys
# Pricing: Starts at $0.003/1K tokens
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-opus-20240229
# ANTHROPIC_MODEL=claude-3-sonnet-20240229
# ANTHROPIC_MODEL=claude-3-haiku-20240307

# =============================================================================
# GOOGLE AI (GEMINI)
# =============================================================================
# Get API key: https://makersuite.google.com/app/apikey
# Pricing: Free tier available with limits
# GOOGLE_API_KEY=...
# GOOGLE_MODEL=gemini-1.5-pro
# GOOGLE_MODEL=gemini-1.5-flash

# =============================================================================
# COHERE (Free Trial Available)
# =============================================================================
# Get API key: https://dashboard.cohere.com/api-keys
# Pricing: Free trial, then pay-per-use
# COHERE_API_KEY=...
# COHERE_MODEL=command-r-plus
# COHERE_MODEL=command-r

# =============================================================================
# AI21 LABS (Free Tier)
# =============================================================================
# Get API key: https://studio.ai21.com/account/api-key
# Pricing: Free tier with 10K tokens/day
# AI21_API_KEY=...
# AI21_MODEL=j2-ultra
# AI21_MODEL=j2-mid

# =============================================================================
# PERPLEXITY API (Affordable)
# =============================================================================
# Get API key: https://www.perplexity.ai/settings/api
# Pricing: $0.0005-0.002/1K tokens
# PERPLEXITY_API_KEY=pplx-...
# PERPLEXITY_MODEL=llama-3.1-sonar-large-128k-online
# PERPLEXITY_MODEL=llama-3.1-sonar-small-128k-online
# PERPLEXITY_BASE_URL=https://api.perplexity.ai

# =============================================================================
# LOCALAI (FREE - Self-hosted, No API Key Required)
# =============================================================================
# Download: https://github.com/mudler/LocalAI
# Pricing: 100% FREE - runs on your hardware
# Setup: docker run -p 8080:8080 localai/localai
# LOCALAI_BASE_URL=http://localhost:8080/v1
# LOCALAI_MODEL=llama-3-8b
# LOCALAI_API_KEY=not-needed

# =============================================================================
# LM STUDIO (FREE - Local Inference GUI)
# =============================================================================
# Download: https://lmstudio.ai/
# Pricing: 100% FREE - beautiful GUI for local models
# Setup: Start LM Studio > Local Server > Start Server
# LMSTUDIO_BASE_URL=http://localhost:1234/v1
# LMSTUDIO_MODEL=local-model
# LMSTUDIO_API_KEY=lm-studio

# =============================================================================
# OLLAMA (FREE - Default Local Option)
# =============================================================================
# Download: https://ollama.ai/download
# Pricing: 100% FREE - runs locally
# Setup: ollama pull llama3.2
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2
# OLLAMA_MODEL=mistral
# OLLAMA_MODEL=codellama
# OLLAMA_MODEL=qwen2.5
# OLLAMA_API_KEY=ollama

# =============================================================================
# MEMORY CONFIGURATION
# =============================================================================
MEMORY_BACKEND=chromadb
MEMORY_PERSIST_DIR=./data/memory
MEMORY_COLLECTION=agent_memory
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# =============================================================================
# API SERVER CONFIGURATION
# =============================================================================
AUTONOMOS_WORKFLOW_API_HOST=0.0.0.0
AUTONOMOS_WORKFLOW_API_PORT=8000
AUTONOMOS_MARKETPLACE_API_HOST=0.0.0.0
AUTONOMOS_MARKETPLACE_API_PORT=8001

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL=sqlite:///./autonomos.db

# =============================================================================
# SCHEDULER CONFIGURATION
# =============================================================================
ENABLE_SCHEDULER=true
TIMEZONE=Asia/Dubai

# =============================================================================
# MESSAGING INTEGRATION (Optional)
# =============================================================================
DISCORD_TOKEN=
SLACK_TOKEN=
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
WHATSAPP_API_KEY=

# =============================================================================
# EMAIL CONFIGURATION (Optional)
# =============================================================================
EMAIL_ADDRESS=
EMAIL_PASSWORD=
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_IMAP_SERVER=imap.gmail.com
EMAIL_IMAP_PORT=993

# =============================================================================
# BROWSER AUTOMATION (Optional)
# =============================================================================
CHROME_HEADLESS=true
CHROME_SANDBOX=false

# =============================================================================
# SECURITY
# =============================================================================
ENABLE_SANDBOX=true
MAX_EXECUTION_TIME=300
WEB_AUTH_TOKEN=your-secret-token-here
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO
LOG_FILE=./data/logs/agent.log

# =============================================================================
# ENVIRONMENT
# =============================================================================
ENVIRONMENT=development
DEBUG=true
