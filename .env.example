# LLM Configuration
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2
LLM_API_KEY=
LLM_BASE_URL=http://localhost:11434

# Alternative LLM Providers (comment out Ollama above to use)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...

# Memory Configuration
MEMORY_BACKEND=chromadb
MEMORY_PERSIST_DIR=./data/memory
MEMORY_COLLECTION=agent_memory
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Scheduler Configuration
ENABLE_SCHEDULER=true
TIMEZONE=Asia/Dubai

# Messaging Integration
DISCORD_TOKEN=
SLACK_TOKEN=
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
WHATSAPP_API_KEY=

# Email Configuration
EMAIL_ADDRESS=
EMAIL_PASSWORD=
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_IMAP_SERVER=imap.gmail.com
EMAIL_IMAP_PORT=993

# Browser Automation
CHROME_HEADLESS=true
CHROME_SANDBOX=false

# Security
ENABLE_SANDBOX=true
MAX_EXECUTION_TIME=300
WEB_AUTH_TOKEN=your-secret-token-here
ALLOWED_ORIGINS=http://localhost:8080

# Logging
LOG_LEVEL=INFO
LOG_FILE=./data/logs/agent.log
