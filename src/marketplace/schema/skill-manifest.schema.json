{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AutonomOS Skill Manifest",
  "type": "object",
  "required": ["name", "version", "description", "author", "entrypoint"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Unique skill identifier (lowercase, hyphens allowed)"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version (e.g., 1.0.0)"
    },
    "description": {
      "type": "string",
      "maxLength": 200,
      "description": "Short skill description"
    },
    "longDescription": {
      "type": "string",
      "description": "Detailed skill description (supports Markdown)"
    },
    "author": {
      "type": "object",
      "required": ["name", "email"],
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "url": { "type": "string", "format": "uri" }
      }
    },
    "license": {
      "type": "string",
      "default": "MIT",
      "description": "SPDX license identifier"
    },
    "category": {
      "type": "string",
      "enum": [
        "productivity",
        "communication",
        "data-processing",
        "automation",
        "integration",
        "ai-ml",
        "utilities",
        "development"
      ]
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "maxItems": 10
    },
    "entrypoint": {
      "type": "string",
      "description": "Main Python module (e.g., main.py)"
    },
    "dependencies": {
      "type": "object",
      "properties": {
        "python": { "type": "string", "default": ">=3.10" },
        "packages": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "permissions": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "network",
          "filesystem",
          "database",
          "api_keys",
          "environment",
          "external_services"
        ]
      },
      "description": "Required permissions for the skill"
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": { "type": "string" },
          "type": { "enum": ["string", "number", "boolean", "object", "array"] },
          "description": { "type": "string" },
          "required": { "type": "boolean", "default": false },
          "default": {}
        }
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": { "type": "string" },
          "type": { "enum": ["string", "number", "boolean", "object", "array"] },
          "description": { "type": "string" }
        }
      }
    },
    "examples": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "input": { "type": "object" },
          "output": {}
        }
      }
    },
    "homepage": {
      "type": "string",
      "format": "uri"
    },
    "repository": {
      "type": "string",
      "format": "uri"
    },
    "icon": {
      "type": "string",
      "description": "Emoji or URL to icon"
    }
  }
}
